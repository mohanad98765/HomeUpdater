# ============================================================
#  HomeUpdater — root .gitignore
#  Patterns without a leading slash match at any depth, so these
#  cover 02_التطوير/backend, 02_التطوير/frontend, etc.
# ============================================================

# --- Python virtual environments (the committed .venv was broken) ---
.venv/
venv/
env/
ENV/

# --- Python caches / build ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Node / Frontend ---
node_modules/
dist/
build/
.vite/

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Logs (generated per run) ---
logs/
*.log

# --- Local database / user data ---
*.db
*.sqlite
*.sqlite3

# --- IDE / editors ---
.vscode/
.idea/
*.swp
*.swo

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Installer / build outputs ---
installer-output/
*.exe
*.msi
!setup.exe

# Claude Code runtime artifacts
.claude/scheduled_tasks.lock

# TypeScript incremental build info
*.tsbuildinfo
